# LLM APIs
GROQ_API_KEY_ORCHESTRATOR=gsk_...
GROQ_API_KEY_FAQ=gsk_...
GROQ_API_KEY_ACTION=gsk_...
GROQ_API_KEY_RAG=gsk_...
GEMINI_API_KEY=AIza...
MISTRAL_API_KEY=...
OPENROUTER_API_KEY=...

# Auth
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ACCESS_EXPIRES=3600
JWT_REFRESH_EXPIRES=604800

# Databases
# Structured app DB: Supabase Postgres connection string.
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI.
STRUCTURE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Vector/RAG DB: Aiven/Supabase Postgres with pgvector for document_chunks.
# Keep this on Aiven if your RAG is already working there, or point it to Supabase too.
VECTOR_DATABASE_URL=postgresql://user:password@host:5432/defaultdb?sslmode=require

# Backward compatibility for older configs. Prefer VECTOR_DATABASE_URL now.
POSTGRES_URL=

REDIS_URL=redis://localhost:6379/0

# Storage Paths
DOCS_PATH=../storage/documents

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=...
SUPABASE_BUCKET=Documents
SUPABASE_DOCUMENTS_BUCKET=Documents
SUPABASE_PROFILES_BUCKET=profiles
SUPABASE_LOGOS_BUCKET=logos

# App
FLASK_ENV=development
FLASK_DEBUG=1
FRONTEND_URL=http://localhost:3000
PORT=5000

# Mail / SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@n7chat.com
