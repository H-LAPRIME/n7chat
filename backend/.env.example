# ─── LLM APIs ─────────────────────────────────────────────────
GROQ_API_KEY_ORCHESTRATOR=gsk_...
GROQ_API_KEY_FAQ=gsk_...
GROQ_API_KEY_ACTION=gsk_...
GEMINI_API_KEY=AIza...
MISTRAL_API_KEY=...
OPENROUTER_API_KEY=...

# ─── Auth ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ACCESS_EXPIRES=3600        # 1 hour  (seconds)
JWT_REFRESH_EXPIRES=604800     # 7 days  (seconds)

# ─── Databases ─────────────────────────────────────────────────
POSTGRES_URL=postgresql://user:password@localhost:5432/n7chat
MONGODB_URL=mongodb://localhost:27017/n7chat
REDIS_URL=redis://localhost:6379/0

# ─── Storage Paths ─────────────────────────────────────────────
DOCS_PATH=../storage/documents
FAISS_INDEX_PATH=../storage/faiss_index

# ─── App ───────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
FRONTEND_URL=http://localhost:3000
PORT=5000
